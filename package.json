{
  "name": "va-worker-time-tracker",
  "version": "0.1.2",
  "description": "Cross-platform worker time tracker desktop app for VA API.",
  "private": true,
  "main": "electron/main.cjs",
  "author": "VA",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "icons": "node scripts/generate-icons.js",
    "dist": "npm run icons && npm run build && electron-builder",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "libsodium-wrappers": "^0.8.4",
    "node-fetch": "^2.7.0",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "optionalDependencies": {
    "iohook": "^0.9.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "rcedit": "^5.0.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.va.worker.timetracker",
    "productName": "VA Trackme",
    "icon": "icon.ico",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "build/icon.ico",
      "build/icon.png",
      "build/icon-16.png",
      "build/icon-24.png",
      "build/icon-32.png",
      "build/icon-48.png",
      "build/icon-64.png",
      "build/icon-128.png",
      "build/icon-256.png",
      "build/icon-512.png",
      "build/icon-1024.png",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/active-win/**/*"
    ],
    "npmRebuild": false,
    "directories": {
      "buildResources": "build",
      "output": "installer-final3"
    },
    "afterPack": "scripts/embed-win-icon.cjs",
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "VA Trackme needs permission to detect the active window for time tracking."
      }
    }
  }
}
